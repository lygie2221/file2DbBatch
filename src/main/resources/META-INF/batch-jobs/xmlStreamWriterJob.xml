<?xml version="1.0" encoding="UTF-8"?>
<job id="xmlStreamWriterJob"
     xmlns="http://xmlns.jcp.org/xml/ns/javaee"
     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                         http://xmlns.jcp.org/xml/ns/javaee/jobXML_1_0.xsd"
     version="1.0">
    <step id="chunkStep">
        <chunk item-count="#{jobParameters['chunkSize']}" retry-limit="0">
            <reader ref="largeFileReader">
                <properties>
                    <property name="chunkSize" value="#{jobParameters['chunkSize']}" />
                </properties>
            </reader>
            <processor ref="largeFile2XmlProcessor"/>
            <writer ref="CDataChunkXmlWriter">
                <properties>
                    <property name="output" value="#{jobParameters['output']}"/>
                    <property name="rootElement" value="root"/>
                    <property name="cdataElement" value="largeData"/>
                    <property name="encoding" value="UTF-8"/>
                </properties>
            </writer>
        </chunk>
    </step>

</job>